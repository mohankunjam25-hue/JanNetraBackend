          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.environment.set(\"accessToken\", jsonData.data.accessToken);",
                  "    console.log(\"Access Token saved to environment\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
